{
  "name": "hardhat_edp",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "test": "npx hardhat test",
    "backend": "node backend/server.js",
    "frontend": "npm --prefix frontend run dev",
    "frontend:build": "npm --prefix frontend run build",
    "frontend:start": "npm --prefix frontend run start",
    "dev": "concurrently \"npm run backend\" \"npm run frontend\"",
    "deploy": "npx hardhat run scripts/deployUnified.js --network sepolia",
    "deploy:local": "npx hardhat run scripts/deployUnified.js",
    "prepare-deploy": "node scripts/prepare-deploy.js",
    "push": "npm run prepare-deploy && git add . && git commit -m \"Sync config for deployment\" && git push"
  },
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.1.2",
    "@nomicfoundation/hardhat-ethers": "^3.1.3",
    "chai": "^4.3.7",
    "hardhat": "^2.28.6"
  },
  "dependencies": {
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.1",
    "ethers": "^6.16.0",
    "express": "^5.2.1"
  }
}
